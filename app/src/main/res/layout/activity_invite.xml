<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.invite.InviteActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Header icon -->
        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginTop="16dp"
            android:src="@android:drawable/ic_menu_share"
            android:contentDescription="@string/invite_title" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/invite_headline"
            android:textAppearance="?attr/textAppearanceHeadline5"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:text="@string/invite_subhead"
            android:textAppearance="?attr/textAppearanceBody1"
            android:gravity="center"
            android:textColor="?android:attr/textColorSecondary" />

        <!-- Share via Bluetooth -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareBluetooth"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:text="@string/share_via_bluetooth"
            app:icon="@android:drawable/stat_sys_data_bluetooth" />

        <!-- Share via Wi-Fi Direct / Nearby Share -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareWifi"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:text="@string/share_via_wifi"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:icon="@android:drawable/ic_menu_upload" />

        <!-- Upload to Google Drive and share link -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareDrive"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:text="@string/share_via_drive"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:icon="@android:drawable/ic_menu_upload" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/invite_note"
            android:textAppearance="?attr/textAppearanceCaption"
            android:textColor="?android:attr/textColorSecondary"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
